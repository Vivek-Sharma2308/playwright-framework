{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node", "@playwright/test"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@data/*": ["src/test-data/*"],
      "@utils/*": ["src/utils/*"]
    }
  }
}